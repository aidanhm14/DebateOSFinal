{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/generate", "destination": "/api/generate" },
    { "source": "/api/refine", "destination": "/api/refine" },
    { "source": "/api/random-resolutions", "destination": "/api/random-resolutions" },
    { "source": "/api/speech-structure", "destination": "/api/speech-structure" },
    { "source": "/api/casual", "destination": "/api/casual" },
    { "source": "/api/adjudicate", "destination": "/api/adjudicate" },
    { "source": "/api/speech-feedback", "destination": "/api/speech-feedback" },
    { "source": "/api/admin/keys", "destination": "/api/admin/keys" },
    { "source": "/api/admin/keys/:id", "destination": "/api/admin/keys/[id]" },
    { "source": "/api/admin/usage", "destination": "/api/admin/usage" },
    { "source": "/api/stripe/create-checkout", "destination": "/api/stripe/create-checkout" },
    { "source": "/api/stripe/webhook", "destination": "/api/stripe/webhook" },
    { "source": "/api/stripe/portal", "destination": "/api/stripe/portal" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  }
}
